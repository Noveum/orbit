{
  "name": "orbit",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.3.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "trustedDependencies": [
    "@biomejs/biome",
    "esbuild",
    "lefthook",
    "sharp"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "dev": "bun run --filter '*' dev",
    "typecheck": "tsc -p scripts/tsconfig.json --noEmit && bun run --filter '*' typecheck",
    "test": "bun run --filter '*' test",
    "test:e2e": "bun run --filter '@orbit/web' test:e2e",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check-comments": "bun scripts/strip-comments.ts --check",
    "strip-comments": "bun scripts/strip-comments.ts",
    "verify": "bun run lint && bun run check-comments && bun run typecheck && bun run test",
    "db:generate": "bun run --filter '@orbit/db' generate",
    "db:migrate": "bun run --filter '@orbit/db' migrate",
    "db:push": "bun run --filter '@orbit/db' push",
    "db:seed": "bun run --filter '@orbit/db' seed",
    "db:studio": "bun run --filter '@orbit/db' studio",
    "db:import-plane": "bun run --filter '@orbit/db' import:plane",
    "db:verify-plane": "bun run --filter '@orbit/db' import:verify",
    "plane:fetch": "bun scripts/fetch-plane.ts",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:reset": "docker compose down -v && docker compose up -d",
    "prepare": "lefthook install || true"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@types/bun": "1.3.14",
    "lefthook": "2.1.10",
    "typescript": "5.9.3"
  }
}
