{
  "name": "@orbit/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "push": "drizzle-kit push --force",
    "studio": "drizzle-kit studio",
    "seed": "tsx --env-file-if-exists=../../.env src/seed/index.ts",
    "import:plane": "tsx --env-file-if-exists=../../.env src/import/index.ts",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@orbit/shared": "workspace:*",
    "drizzle-orm": "0.45.2",
    "pg": "8.22.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pg": "8.20.0",
    "drizzle-kit": "0.31.10",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
