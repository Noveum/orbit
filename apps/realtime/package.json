{
  "name": "@orbit/realtime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun --watch --env-file=../../.env src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist --minify",
    "start": "bun dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@orbit/core": "workspace:*",
    "@orbit/db": "workspace:*",
    "@orbit/shared": "workspace:*",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@orbit/realtime-client": "workspace:*",
    "@types/bun": "1.3.14",
    "typescript": "5.9.3"
  }
}
